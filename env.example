# Node-only: offline eval suite + CLI (pnpm eval). NOT exposed to the browser.
# --- Chat provider keys (pnpm eval uses the one named by EVAL_PROVIDER) ---
GEMINI_API_KEY=${GEMINI_API_KEY}        # provider: google-genai (default)
OPENAI_API_KEY=${OPENAI_API_KEY}        # provider: openai
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}    # provider: deepseek (OpenAI-compatible)

# --- Eval provider selection (optional; defaults to google-genai / gemini-2.5-flash) ---
# Run the suite on an OpenAI-compatible provider when the Gemini quota is exhausted.
# EVAL_PROVIDER=deepseek                # google-genai | openai | deepseek
# EVAL_MODEL=deepseek-chat              # overrides the provider's default model
# EVAL_BASE_URL=https://...             # custom OpenAI-compatible endpoint (openai/deepseek)

LANGSMITH_API_KEY=${LANGSMITH_API_KEY}
LANGSMITH_TRACING=true
# Defaults to EU in code when unset; override for US keys.
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=  # required for some org-scoped API keys

# Web app dev convenience ONLY. Exposed to the client via import.meta.env, but the
# app reads it only when import.meta.env.DEV is true (services/apiKey.ts), so it is
# never inlined into a production build. In prod the key is BYOK via ApiModal.
VITE_GEMINI_API_KEY=${GEMINI_API_KEY}
